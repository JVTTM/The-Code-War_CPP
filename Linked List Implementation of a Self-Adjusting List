#include <iostream>
using namespace std;

struct SelfAdjustingList {
private:
	struct Node {
		int data;
		Node* next;
		Node(int value) :data(value), next(nullptr) {}
	};
	Node* head;

public:
	SelfAdjustingList() {
		head = nullptr;
	}

	~SelfAdjustingList() {
		while (head) {
			Node* temp = head;
			head = head->next;
			delete temp;
		}
	}

	void insert(int x) {
		Node* newNode = new Node(x);
		newNode->next = head;
		head = newNode;
	}

	bool find(int x) {
		if (!head) return false;

		if (head->data == x) {
			return true;
		}

		Node* previous = head;
		Node* current = head->next;

		while (current) {
			if (current->data == x) {
				previous->next = current->next;

				current->next = head;
				head = current;
				return true;
			}
			previous = current;
			current = current->next;
		}
		return false;
	}

	void print() {
		Node* temp = head;
		while (temp) {
			cout << temp->data << " ";;
			temp = temp->next;
		}
		cout << endl;
	}
};

int main() {
	SelfAdjustingList list;

	list.insert(13);
	list.insert(20);
	list.insert(18);
	list.insert(10);

	cout << "List after inserting values: ";
	list.print();

	list.find(20);
	cout << "List after accessing a element using find: ";
	list.print();

	return 0;
}
