#include <iostream>
#include <cmath>
#include <cctype>
#include <string>
#include <algorithm>
using namespace std;

string status(float bmi) {
	if (bmi < 18.5) {
		return "underweight";
	}
	else if (bmi>= 18.5 && bmi < 24.9) {
		return "healthy";
	}
	else if (bmi >= 25 && bmi < 29.9) {
		return "overweight";
	}
	else if (bmi >= 30 && bmi < 34.9) {
		return "class 1 obese";
	}
	else if (bmi >= 35 && bmi < 39.9) {
		return "class 2 obese";
	}
	else {
		return "class 3 obese";
	}
}

int main()
{
	string measurementSystem;
	string chart;
	float weight;
	float height;
	float bmi;

	cout << "Metric or Imperial system: ";
	getline(cin,measurementSystem);
	transform(measurementSystem.begin(), measurementSystem.end(), measurementSystem.begin(),[](unsigned char c) { return tolower(c); });
	
	if (measurementSystem == "metric") {
		cout << "Please enter your weight(kg): ";
		cin >> weight;
		cout << "Please enter your height(meters): ";
		cin >> height;
		bmi = weight / pow(height,2);
		chart = status(bmi);
		cout << "Your BMI is " << bmi << " and you are considered "<<chart;
	}
	else if (measurementSystem == "imperial") {
		cout << "Please enter your weight(lb): ";
		cin >> weight;
		cout << "Please enter your height(inches): ";
		cin >> height;
		bmi = weight / pow(height, 2) * 703;
		chart = status(bmi);
		cout << "Your BMI is " << bmi << " and you are considered "<<chart;
	}
}
